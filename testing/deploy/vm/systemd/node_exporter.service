[Unit]
Description=Prometheus node_exporter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=node_exporter
Group=node_exporter
# Install the binary from https://prometheus.io/download/#node_exporter
ExecStart=/usr/local/bin/node_exporter
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
