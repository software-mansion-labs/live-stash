# read by livestash-app.service

SECRET_KEY_BASE=REPLACE_WITH_mix_phx.gen.secret
PHX_SERVER=true
PHX_HOST=APP_VM_1
PORT=4000

LIVE_STASH_REDIS_URL=redis://REDIS_VM:6379

# Clustering
# Open EPMD (4369) + the Erlang distribution port range
# between the app VMs, and use the SAME cookie everywhere.
#
# Per-VM: RELEASE_NODE is unique per node; everything else is identical.
#   APP_VM_1 -> RELEASE_NODE=testing@APP_VM_1
#   APP_VM_2 -> RELEASE_NODE=testing@APP_VM_2
RELEASE_DISTRIBUTION=name
RELEASE_NODE=testing@APP_VM_1
RELEASE_COOKIE=REPLACE_WITH_A_SHARED_SECRET
# DNSCluster connects to every node a DNS name resolves to. Point this at an
# internal/headless record that returns ALL app VM IPs.
DNS_CLUSTER_QUERY=testing.internal
