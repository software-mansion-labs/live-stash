# read by livestash-app.service

SECRET_KEY_BASE=REPLACE_WITH_mix_phx.gen.secret
PHX_SERVER=true
# This VM's own private IP. app-1 -> 10.10.0.3, app-2 -> 10.10.0.4
PHX_HOST=10.10.0.3
PORT=4000

LIVE_STASH_REDIS_URL=redis://10.10.0.5:6379

# Performance harness (seconds / ms). configure_app_perf.sh updates these.
LIVE_STASH_TTL=60
LIVE_STASH_ETS_CLEANUP_INTERVAL_MS=30000
LIVE_STASH_MNESIA_CLEANUP_INTERVAL_MS=30000

# Clustering
# Erlang distribution over the private network. EPMD (4369) + the distribution
# port range must be reachable between the app VMs (a broad UFW rule allowing
# the private subnet covers this). Use the SAME cookie everywhere.
#
# Per-VM: RELEASE_NODE is unique per node; everything else is identical.
#   app-1 -> RELEASE_NODE=testing@10.10.0.3
#   app-2 -> RELEASE_NODE=testing@10.10.0.4
RELEASE_DISTRIBUTION=name
RELEASE_NODE=testing@10.10.0.3
RELEASE_COOKIE=REPLACE_WITH_A_SHARED_SECRET

# libcluster Epmd strategy: full list of node names to connect to (identical on
# every app VM). Read by application.ex.
CLUSTER_HOSTS=testing@10.10.0.3,testing@10.10.0.4
