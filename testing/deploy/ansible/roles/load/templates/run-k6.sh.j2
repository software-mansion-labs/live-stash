#!/usr/bin/env bash
# Managed by Ansible. Run the load test on the load VM.
# Usage:
#   /opt/k6/run-k6.sh -e BASE_PATH=/performance/livestash_redis
# k6 hits the local nginx LB on this VM's private IP (not 127.0.0.1 — loopback
# shares one ~64k ephemeral-port pool and exhausts around 15–20k long-lived WS).
# Override HOST to target a single app node, e.g. HOST=10.10.0.3:4000.
set -euo pipefail

ulimit -n 1048576 || true

OBS_VM="${OBS_VM:-{{ obs_private_ip }}}"
HOST="${HOST:-{{ load_private_ip }}:80}"
TEST="/opt/k6/load_test.js"

export HOST
export K6_PROMETHEUS_RW_SERVER_URL="${K6_PROMETHEUS_RW_SERVER_URL:-http://${OBS_VM}:9090/api/v1/write}"
export K6_PROMETHEUS_RW_TREND_AS_NATIVE_HISTOGRAM=true
# Default flush is 5s; at 20k+ VUs the push to Prometheus can overrun that window.
export K6_PROMETHEUS_RW_PUSH_INTERVAL="${K6_PROMETHEUS_RW_PUSH_INTERVAL:-10s}"

exec k6 run --out=experimental-prometheus-rw "$TEST" "$@"
